@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Eigen3)
find_dependency(Boost)
find_dependency(NLopt)

if(UNIX)
    find_dependency(TBB)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/GbsTargets.cmake")

if(@GBS_USE_RENDER@)
    find_dependency(VTK QUIET)
endif()

if(@GBS_USE_OCCT_UTILS@)
    find_dependency(OpenCASCADE QUIET)
endif()
